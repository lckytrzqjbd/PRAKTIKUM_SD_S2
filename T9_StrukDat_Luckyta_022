#include <iostream>
using namespace std;

int main() {
    string data[] = {"zebra", "ayam", "sapi", "kambing"};
    int n = 4;

    cout << "Original Array: ";
    for(int i = 0; i < n; i++) {
        cout << data[i] << " ";
    }

    // Bubble Sort Descending
    for(int i = 0; i < n-1; i++) {
        for(int j = 0; j < n-1-i; j++) {
            if(data[j] < data[j+1]) {
                string temp = data[j];
                data[j] = data[j+1];
                data[j+1] = temp;
            }
        }
    }

    cout << endl;
    cout << "Sorted Array (Descending): ";

    for(int i = 0; i < n; i++) {
        cout << data[i] << " ";
    }

    return 0;
}
