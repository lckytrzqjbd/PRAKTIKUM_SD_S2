#include <iostream>
using namespace std;

int count;
void sequentialSearch(int arr[], int n, int search) {
	bool found = false;
	for (int i = 0; i < n; i++) {
	    
		if (arr[i] == search) {
			cout << "'" << search << "'" << "ditemukan pada indeks ke-" << i << endl;
			count ++;
			     found = true;
		}
	}

	if (!found) {
		cout << "'" << search << "' tidak ditemukan dalam array." << endl;
	}
}

    int main() {
	int listArray[] = {9,2,5,2,7,6,11,2};
	int n = sizeof(listArray) / sizeof(listArray[0]);
	int search = 2;

    cout << "Data Array: ";
	for(int i = 0; i < n; i++) {
		cout << listArray[i] << " ";
	}
	cout << "\n\n";

	cout << "Mencari angka " << search << " ... " << endl;
	sequentialSearch(listArray, n, search);
	cout << "Jumlah angka " << search << " ditemukan sebanyak " << count << " kali.";
	

	return 0;
}
